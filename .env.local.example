# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Trading mode (safe defaults) ──────────────────────────────
DEFAULT_EXCHANGE=binance
DEFAULT_ACTIVE_EXCHANGE=binance
DEFAULT_TRADING_MODE=paper
HARD_LIVE_TRADING_ALLOWED=false

# ── Binance (read-only market data; no live order placement) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_WS_URL=wss://fstream.binance.com

# ── LLM (optional — analysis only, never executes trades) ─────
LLM_PROVIDER=openai
LLM_MODEL=
LLM_API_KEY=
LLM_ENABLED=false

# ── Risk policy (optional — safe defaults apply if unset) ─────
MAX_LEVERAGE=3
MAX_ALLOWED_LEVERAGE=5
MAX_RISK_PER_TRADE_PERCENT=1
MAX_DAILY_LOSS_PERCENT=5
MAX_WEEKLY_LOSS_PERCENT=10
DAILY_PROFIT_TARGET_USD=20
MAX_OPEN_POSITIONS=2
MIN_RISK_REWARD_RATIO=2

# ── Credential encryption (32+ char random string) ────────────
CREDENTIAL_ENCRYPTION_KEY=
