# ============================================================
# VERCEL PRODUCTION ENV TEMPLATE
# Vercel Dashboard → Project → Settings → Environment Variables
# Add each variable below. Never commit real secret values.
# ============================================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZORUNLU — Supabase
# Supabase Dashboard → Project Settings → API
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZORUNLU — Credential encryption key
# Stored API key/secret'leri AES-GCM ile şifreler.
# Vercel ile worker'da aynı değer kullanılmalı.
# Üretim: openssl rand -base64 32
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CREDENTIAL_ENCRYPTION_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZORUNLU — Safety gates
# 100 paper trade tamamlanana kadar false kalacak.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HARD_LIVE_TRADING_ALLOWED=false
LIVE_TRADING=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZORUNLU — Exchange defaults
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DEFAULT_EXCHANGE=binance
DEFAULT_ACTIVE_EXCHANGE=binance
DEFAULT_TRADING_MODE=paper
DEFAULT_MARKET_TYPE=futures
DEFAULT_MARGIN_MODE=isolated

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZORUNLU — Binance endpoint'leri
# Paper mode için bile gereklidir (public market data).
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_WS_URL=wss://fstream.binance.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Opsiyonel — Risk limitleri (env yoksa kod içi default değerler kullanılır)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
MAX_LEVERAGE=3
MAX_ALLOWED_LEVERAGE=5
MAX_RISK_PER_TRADE_PERCENT=1
MAX_DAILY_LOSS_PERCENT=3
MAX_WEEKLY_LOSS_PERCENT=10
DAILY_PROFIT_TARGET_USD=20
MAX_OPEN_POSITIONS=2
MIN_RISK_REWARD_RATIO=2
MAX_CONSECUTIVE_LOSSES=3
MIN_STRATEGY_HEALTH_SCORE_TO_TRADE=60

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Opsiyonel — Binance API (dashboard → API Settings üzerinden da eklenebilir)
# Paper mode için gerekmez. Live mode için zorunlu.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Opsiyonel — LLM (analiz amaçlı; emir göndermez)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
