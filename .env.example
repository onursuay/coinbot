# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-side credential encryption (32+ char random secret)
CREDENTIAL_ENCRYPTION_KEY=

# Trading mode and defaults
LIVE_TRADING=false
DEFAULT_TRADING_MODE=paper
DEFAULT_MARKET_TYPE=futures
DEFAULT_MARGIN_MODE=isolated
DEFAULT_ACTIVE_EXCHANGE=mexc

# Risk policy
MAX_LEVERAGE=3
MAX_ALLOWED_LEVERAGE=5
MAX_RISK_PER_TRADE_PERCENT=1
MAX_DAILY_LOSS_PERCENT=5
MAX_WEEKLY_LOSS_PERCENT=10
DAILY_PROFIT_TARGET_USD=20
MAX_DAILY_PROFIT_TARGET_USD=50
MAX_OPEN_POSITIONS=2
MIN_RISK_REWARD_RATIO=2

# Exchange credentials (server-only; never exposed to client)
MEXC_API_KEY=
MEXC_API_SECRET=

BINANCE_API_KEY=
BINANCE_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

BYBIT_API_KEY=
BYBIT_API_SECRET=
