# ============================================================
# VERCEL ENV TEMPLATE — copy to Vercel Dashboard → Settings → Environment Variables
# Never commit real values. This file shows VARIABLE NAMES only.
# ============================================================

# ── Supabase (REQUIRED) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Credential encryption (REQUIRED) ────────────────────────
# 32+ random chars — used to encrypt Binance API key/secret at rest
# Generate: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=GENERATE_WITH_OPENSSL_RAND

# ── Safety gates (keep false until 100 paper trades done) ───
HARD_LIVE_TRADING_ALLOWED=false
LIVE_TRADING=false

# ── Default bot settings (used on first DB row creation) ────
DEFAULT_TRADING_MODE=paper
DEFAULT_MARKET_TYPE=futures
DEFAULT_MARGIN_MODE=isolated
DEFAULT_ACTIVE_EXCHANGE=binance

# ── Risk caps ───────────────────────────────────────────────
MAX_LEVERAGE=3
MAX_ALLOWED_LEVERAGE=5
MAX_RISK_PER_TRADE_PERCENT=1
MAX_DAILY_LOSS_PERCENT=3
MAX_WEEKLY_LOSS_PERCENT=10
DAILY_PROFIT_TARGET_USD=20
MAX_OPEN_POSITIONS=2
MIN_RISK_REWARD_RATIO=2
MAX_CONSECUTIVE_LOSSES=3
MIN_STRATEGY_HEALTH_SCORE_TO_TRADE=60

# ── LLM (optional — analysis only, never executes orders) ───
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# ── Binance (optional on dashboard — add via exchange connect UI) ──
# These can also be added encrypted via the dashboard → API Settings
# If set here, they are used as fallback for market data only.
BINANCE_API_KEY=
BINANCE_API_SECRET=
