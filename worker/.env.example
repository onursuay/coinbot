# ============================================================
# WORKER ENV TEMPLATE — VPS / Docker / Railway / Fly.io
# Copy to .env (or pass via -e flags / docker-compose env_file)
# Never commit real values.
# ============================================================

# ── Supabase (REQUIRED) ─────────────────────────────────────
# NOTE: variable name is NEXT_PUBLIC_SUPABASE_URL (not SUPABASE_URL)
# This matches the env variable read by env.ts in both dashboard and worker.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Credential encryption (REQUIRED — must match Vercel value) ──
CREDENTIAL_ENCRYPTION_KEY=SAME_KEY_AS_VERCEL

# ── Worker identity ──────────────────────────────────────────
WORKER_ID=vps-prod-1

# ── Tick & heartbeat intervals ───────────────────────────────
TICK_INTERVAL_SEC=30
HEARTBEAT_INTERVAL_SEC=15

# ── Safety gates ────────────────────────────────────────────
# Keep false until 100 paper trades completed and live readiness passes
HARD_LIVE_TRADING_ALLOWED=false

# ── Binance (required for live mode; market data uses public API) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Risk caps (must match Vercel values) ────────────────────
MAX_LEVERAGE=3
MAX_ALLOWED_LEVERAGE=5
MAX_RISK_PER_TRADE_PERCENT=1
MAX_DAILY_LOSS_PERCENT=3
MAX_WEEKLY_LOSS_PERCENT=10
DAILY_PROFIT_TARGET_USD=20
MAX_OPEN_POSITIONS=2
MIN_RISK_REWARD_RATIO=2
MIN_STRATEGY_HEALTH_SCORE_TO_TRADE=60
