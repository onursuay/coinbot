# ============================================================
# WORKER ENV TEMPLATE — VPS / Docker / Railway / Fly.io
# cp worker/.env.example worker/.env  →  değerleri doldur
# worker/.env git tarafından ignore edilir — commit etme.
#
# KRITIK: Vercel ile aynı NEXT_PUBLIC_SUPABASE_URL ve
# CREDENTIAL_ENCRYPTION_KEY kullanılmalı (eşleşmezse
# şifreli API key'ler çözülemez).
# ============================================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZORUNLU — Supabase
# NOT: değişken adı NEXT_PUBLIC_SUPABASE_URL (SUPABASE_URL değil)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZORUNLU — Vercel'deki değerin TAM KOPYASI olmalı
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CREDENTIAL_ENCRYPTION_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZORUNLU — Worker kimliği (her worker için benzersiz olmalı)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
WORKER_ID=vps-prod-1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZORUNLU — Safety gate (100 paper trade bitene kadar false)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HARD_LIVE_TRADING_ALLOWED=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ZORUNLU — Exchange defaults
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DEFAULT_EXCHANGE=binance
DEFAULT_ACTIVE_EXCHANGE=binance
DEFAULT_TRADING_MODE=paper
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_WS_URL=wss://fstream.binance.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Opsiyonel — Tick/heartbeat aralıkları
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TICK_INTERVAL_SEC=30
HEARTBEAT_INTERVAL_SEC=15

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Opsiyonel — Binance API (paper mode için gerekmez)
# Live mode için zorunlu.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Opsiyonel — Risk limitleri (Vercel ile eşleşmeli)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
MAX_LEVERAGE=3
MAX_ALLOWED_LEVERAGE=5
MAX_RISK_PER_TRADE_PERCENT=1
MAX_DAILY_LOSS_PERCENT=3
MAX_WEEKLY_LOSS_PERCENT=10
MAX_OPEN_POSITIONS=2
MIN_RISK_REWARD_RATIO=2
MIN_STRATEGY_HEALTH_SCORE_TO_TRADE=60

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Opsiyonel — LLM (analiz; emir göndermez)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LLM_ENABLED=false
LLM_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Opsiyonel — Email monitoring raporları (her 30 dakikada)
# SMTP_FROM için domain doğrulaması gerekir (SPF/DKIM/DMARC).
# Resend kullanıyorsanız: resend.com → Domains → onursuay.com ekle
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REPORT_EMAIL_ENABLED=true
REPORT_EMAIL_INTERVAL_MINUTES=30
REPORT_EMAIL_TO=onursuay@hotmail.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxx
SMTP_FROM=coin@onursuay.com

# Log temizliği
LOG_RETENTION_ENABLED=true
LOG_CLEANUP_INTERVAL_HOURS=24
